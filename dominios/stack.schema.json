{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "pages",
    "public_domains",
    "workers"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "primary_domain"
      ],
      "properties": {
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "primary_domain": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "pages": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client",
        "bot"
      ],
      "properties": {
        "client": {
          "$ref": "#/$defs/pageTarget"
        },
        "bot": {
          "$ref": "#/$defs/pageTarget"
        }
      }
    },
    "workers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/worker"
      }
    },
    "public_domains": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "legacy"
      ],
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "legacy": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  },
  "$defs": {
    "pageTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory",
        "pages_project",
        "production_branch",
        "origin_url"
      ],
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "pages_project": {
          "type": "string",
          "minLength": 1
        },
        "production_branch": {
          "type": "string",
          "minLength": 1
        },
        "origin_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pattern"
      ],
      "properties": {
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "zone_name": {
          "type": "string",
          "minLength": 1
        },
        "custom_domain": {
          "type": "boolean"
        },
        "zone_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "kvNamespace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding",
        "id"
      ],
      "properties": {
        "binding": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "preview_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "directory",
        "entry",
        "compatibility_date",
        "routes",
        "vars"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "entry": {
          "type": "string",
          "minLength": 1
        },
        "compatibility_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/route"
          }
        },
        "vars": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "kv_namespaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/kvNamespace"
          }
        },
        "seo": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "canonical_origin",
            "hreflang_tags"
          ],
          "properties": {
            "canonical_origin": {
              "type": "string",
              "format": "uri"
            },
            "xdefault_origin": {
              "type": "string",
              "format": "uri"
            },
            "hreflang_tags": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "lang",
                  "origin"
                ],
                "properties": {
                  "lang": {
                    "type": "string",
                    "minLength": 1
                  },
                  "origin": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
